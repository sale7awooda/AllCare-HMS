# AllCare HMS — Environment Configuration
# Copy this file to .env and fill in the values

# ===== REQUIRED IN PRODUCTION =====
# A strong random string used to sign JWT tokens. Generate one with:
#   node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=

# ===== OPTIONAL =====
# Server port (default: 3001)
PORT=3001

# Set to 'production' to enable security hardening (fail on missing JWT_SECRET, hide error details, etc.)
NODE_ENV=development

# Allowed CORS origins (comma-separated).
#
# PRODUCTION (single-server mode):
#   Leave this BLANK. The frontend is served by the same server, so all
#   requests are same-origin and CORS is not needed. Leaving it blank
#   means the server will reflect any origin, which is fine behind a LAN.
#
# DEVELOPMENT (npm run dev):
#   Set to http://localhost:3000 so the Vite dev server can reach the backend.
#   If accessing the dev server from another PC, add that PC's URL too:
#   ALLOWED_ORIGINS=http://localhost:3000,http://192.168.1.XX:3000
#
ALLOWED_ORIGINS=

# Custom database file path (default: backend/allcare.db)
# DB_PATH=./allcare.db
