# AllCare HMS — Environment Configuration
# Copy this file to .env and fill in the values

# ===== REQUIRED IN PRODUCTION =====
# A strong random string used to sign JWT tokens. Generate one with:
#   node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=

# ===== OPTIONAL =====
# Server port (default: 3001)
PORT=3001

# Set to 'production' to enable security hardening (fail on missing JWT_SECRET, hide error details, etc.)
NODE_ENV=development

# Allowed CORS origins, comma-separated (default: same-origin only)
# Example: ALLOWED_ORIGINS=http://localhost:3000,https://yourdomain.com
ALLOWED_ORIGINS=http://localhost:3000

# Custom database file path (default: backend/allcare.db)
# DB_PATH=./allcare.db
